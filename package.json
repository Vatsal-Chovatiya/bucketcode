{
  "name": "bucketcode",
  "private": true,
  "scripts": {
    "dev:full": "bash scripts/setup-local.sh && turbo run dev --filter=!@repo/runner",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "bun test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
