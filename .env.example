# =============================================================================
# BucketCode — Root Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values before running locally.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Database (Neon Postgres 17 — single URL config)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/bucketcode?sslmode=require"

# ---------------------------------------------------------------------------
# S3 / MinIO (Object Storage for repl code & templates)
# ---------------------------------------------------------------------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="bucketcode-repls"
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
JWT_SECRET="change-me-in-production"

# ---------------------------------------------------------------------------
# Service Ports (optional overrides — these match the defaults in source)
# ---------------------------------------------------------------------------
# HTTP_BACKEND_PORT=3001
# ORCHESTRATOR_PORT=3002
# WS_BACKEND_PORT=3003

# ---------------------------------------------------------------------------
# Kubernetes (optional — defaults work for Docker Desktop K8s)
# ---------------------------------------------------------------------------
# K8S_NAMESPACE="default"
# PREVIEW_DOMAIN="localtest.me"
